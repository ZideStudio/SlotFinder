{
  "languages": {
    "Go": {
      "format_on_save": "on",
      "formatter": "language_server",
      "language_servers": ["gopls"]
    },
    "TypeScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--prefix",
            "/workspace/front",
            "oxfmt",
            "--stdin-filepath",
            "{buffer_path}",
            "-c",
            "/workspace/front/.oxfmtrc.json"
          ]
        }
      }
    },
    "TSX": {
