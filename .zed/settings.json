  "lsp": {
    "gopls": {
      "binary": {
        "path": "gopls",
        "arguments": []
      },
      "settings": {
        "gopls": {
          "ui.completion.usePlaceholders": true,
          "ui.diagnostic.analyses": {
            "unusedparams": true,
            "shadow": true
          }
        }
      }
    }
  },
  "terminal": {
    "working_directory": "current_project_directory"
  },
  "code_actions_on_format": {
    "source.organizeImports": true
  }
}
