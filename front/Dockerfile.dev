FROM ubuntu:24.04

WORKDIR /app

# Install dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install mise
RUN curl -fsSL https://github.com/jdx/mise/releases/download/v2026.4.26/mise-v2026.4.26-linux-x64 -o /tmp/mise && \
    echo "CHECKSUM_HERE /tmp/mise" | sha256sum -c - && \
    mv /tmp/mise /usr/local/bin/mise && \
    chmod +x /usr/local/bin/mise

ENV MISE_HOME="/root/.local/share/mise"
ENV PATH="/root/.local/share/mise/shims:/root/.local/bin:${PATH}"

# Copy mise configuration
COPY .mise.toml ./

# Install Node.js and npm via mise
RUN /root/.local/bin/mise install

# Copy application
COPY ./ ./

COPY docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 3000

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["npm", "run", "start"]
