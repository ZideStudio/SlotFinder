{
  "name": "slotfinder-front",
  "version": "0.1.0",
  "description": "SlotFinder front-end",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "rsbuild dev",
    "start:mock": "rsbuild dev --port 3003 --env-mode mock",
    "start:storybook": "storybook dev -p 3002",
    "build": "rsbuild build",
    "build:storybook": "storybook build",
    "preview": "rsbuild preview",
    "test": "vitest run --config config/vitest/workspace.ts",
    "test:unit": "vitest run --config config/vitest/vitest.unit.config.ts",
    "test:unit:watch": "vitest --config config/vitest/vitest.unit.config.ts",
    "test:browser": "vitest --config=config/vitest/vitest.browser.config.ts --run",
    "test:browser:update": "vitest --config=config/vitest/vitest.browser.config.ts --run --update",
    "test:browser:watch": "vitest --config=config/vitest/vitest.browser.config.ts",
    "lint": "node scripts/lint.js",
    "lint:oxlint": "oxlint src/ mocks/",
    "lint:oxlint:fix": "oxlint --fix src/ mocks/",
    "lint:stylelint": "stylelint \"src/**/*.{scss,css}\"",
    "lint:stylelint:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
    "lint:oxfmt": "oxfmt --check src/ mocks/ public/",
    "lint:oxfmt:fix": "oxfmt src/ mocks/ public/",
    "lint:tsc": "tsc --noEmit",
    "package:check": "npm exec --yes package-lock-utd@1.1.3",
    "postinstall": "msw init",
    "i18next-resources-for-ts": "i18next-resources-for-ts toc -i ./src/i18n/locales/en -o ./src/i18n/@types/resources.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@material-symbols/svg-400": "0.45.2",
    "@tanstack/react-query": "5.101.1",
    "i18next": "26.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-i18next": "17.0.8",
    "react-router": "8.0.1",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@pplancq/postcss-config": "3.0.6",
    "@pplancq/stylelint-config": "5.0.3",
    "@rsbuild/core": "2.0.15",
    "@rsbuild/plugin-react": "2.1.0",
    "@rsbuild/plugin-sass": "2.0.0",
    "@rsbuild/plugin-svgr": "2.0.4",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-onboarding": "10.4.6",
    "@tanstack/react-query-devtools": "5.101.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "chromatic": "17.6.0",
    "concurrently": "10.0.3",
    "i18next-resources-for-ts": "2.1.0",
    "jsdom": "29.1.1",
    "monocart-coverage-reports": "2.12.12",
    "msw": "2.14.6",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "remark-gfm": "4.0.1",
    "storybook": "10.4.6",
    "storybook-react-rsbuild": "3.3.4",
    "stylelint": "17.14.0",
    "stylelint-scss": "7.2.0",
    "tsc-files": "1.1.4",
    "typescript": "6.0.3",
    "vite-plugin-svgr": "5.2.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9",
    "vitest-axe": "1.0.0-pre.5",
    "vitest-browser-react": "2.2.0",
    "vitest-sonar-reporter": "3.0.0"
  },
  "msw": {
    "workerDirectory": [
      "./public"
    ]
  }
}
